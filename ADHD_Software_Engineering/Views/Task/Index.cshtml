@model List<ADHD_Software_Engineering.Models.TaskItem>

@{
    ViewData["Title"] = "Task List";
}

<div class="container">
    <h1 class="page-title">Task List</h1>

    <section class="card task-page-card">
        <div class="table-section">
            <h2 class="section-title">Task List</h2>

            <table class="task-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Due Date</th>
                        <th>Status</th>
                        <th>Subtasks</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var task in Model)
                    {
                        <tr>
                            <td>@task.Title</td>
                            <td>@(task.DueDate?.ToString("MMM dd") ?? "N/A")</td>
                            <td>@task.Status</td>
                            <td>
                                @if (task.Subtasks.Any())
                                {
                                    <ul>
                                        @foreach (var subtask in task.Subtasks)
                                        {
                                            <li>@subtask.Title</li>
                                        }
                                    </ul>
                                }
                                else
                                {
                                    <span>No subtasks</span>
                                }
                            </td>
                            <td class="actions-cell">
                                <a asp-controller="Task" asp-action="Edit" asp-route-id="@task.Id" class="task-action-btn">
                                    Edit
                                </a>

                                <form asp-controller="Task" asp-action="Delete" asp-route-id="@task.Id" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="task-action-btn delete-btn"
                                            onclick="return confirm('Delete this task?');">
                                        Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="center">
            <a asp-controller="Task" asp-action="Create" class="btn-primary">+ Add Task</a>
        </div>
    </section>
</div>