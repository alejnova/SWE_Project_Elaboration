@model List<ADHD_Software_Engineering.Models.TaskItem>

@{
    ViewData["Title"] = "Task Dashboard";
    var dueToday = Model.Where(t => t.DueDate.HasValue && t.DueDate.Value.Date == DateTime.Today).ToList();
    var completed = Model.Count(t => t.Status == "Done");
    var progress = Model.Count == 0 ? 0 : (int)((double)completed / Model.Count * 100);
}

<div class="container">
    <h1 class="page-title">Task Dashboard</h1>
    <h2 class="welcome-text">Welcome, Sherlock</h2>

    <div class="card">
        <h3>Tasks Due Today</h3>
        <ul class="task-list">
            @if (dueToday.Any())
            {
                @foreach (var task in dueToday)
                {
                    <li>@task.Title</li>
                }
            }
            else
            {
                <li>No tasks due today</li>
            }
        </ul>
    </div>

    <div class="card">
        <h3>Progress</h3>
        <div class="progress-bar">
            <div class="progress-fill" style="width: @progress%;"></div>
        </div>
        <p class="progress-text">@progress% complete</p>
    </div>

    <div class="card">
        <h3>Upcoming Tasks</h3>
        <ul class="upcoming-list">
            @foreach (var task in Model.Where(t => t.DueDate.HasValue).OrderBy(t => t.DueDate).Take(5))
            {
                <li>@task.Title - @(task.DueDate?.ToString("MMM dd"))</li>
            }
        </ul>
    </div>

    <div class="center">
        <a asp-controller="Task" asp-action="Create" class="btn-primary">+ Add Task</a>
    </div>
</div>
